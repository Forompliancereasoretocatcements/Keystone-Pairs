class Node:
    def __init__(self, value):
        self.value = value
        self.left = None
        self.right = None

class BinarySearchTree:
    def __init__(self, nums):
        nums.sort()
        self.nums = nums
        self.root = self.make_bst(0, len(self.nums) - 1)
    
    def make_bst(self, start, end):
        if start > end:
            return None
        mid = (start + end) // 2
        root = Node(self.nums[mid])
        root.left = self.make_bst(start, mid - 1)
        root.right = self.make_bst(mid + 1, end)
        return root

    def add(self, value):
        if self.root is None:
            self.root = Node(value)
            return
        node = self.root
        while True:
            if value < node.value:
                if node.left is None:
                    node.left = Node(value)
                    return
                node = node.left
            elif value == node.value:
                return
            else:
                if node.right is None:
                    node.right = Node(value)
                    return
                node = node.right

    def delete(self, deletenode, parentnode = None):
        if parentnode is None:
            parentnode = self.findparent(deletenode.value)
        if deletenode.left is deletenode.right is None:
            if deletenode is self.root:
                self.root = None
            elif parentnode.left is deletenode:
                parentnode.left = None
            else:
                parentnode.right = None
        elif deletenode.left is not None and deletenode.right is None:
            if deletenode is self.root:
                self.root = deletenode.left
            elif parentnode.left is deletenode:
                parentnode.left = deletenode.left
            else:
                parentnode.right = deletenode.left
        elif deletenode.left is None and deletenode.right is not None:
            if deletenode is self.root:
                self.root = deletenode.right
            elif parentnode.left is deletenode:
                parentnode.left = deletenode.right
            else:
                parentnode.right = deletenode.right
        else:
            replacenode = deletenode.right
            parentreplacenode = deletenode
            while replacenode.left is not None:
                parentreplacenode = replacenode
                replacenode = replacenode.left
            deletenode.value = replacenode.value
            self.delete(replacenode, parentreplacenode)

    def findnodeandparent(self, value):
        node = self.root
        parentnode = None
        while value != node.value:
            if value < node.value:
                if node.left is None:
                    return
                parentnode = node
                node = node.left
            else:
                if node.right is None:
                    return
                parentnode = node
                node = node.right
        return [node, parentnode]

    def find(self, value):
        return self.findnodeandparent(value)[0]

    def findparent(self, value):
        return self.findnodeandparent(value)[1]

    def size(self, node = None):
        if node is None:
            node = self.root
        if node.left is node.right is None:
            return node.value
        if node.left is not None and node.right is None:
            return node.value + self.size(node.left)
        if node.left is None and node.right is not None:
            return node.value + self.size(node.right)
        return node.value + self.size(node.left) + self.size(node.right)

    def calculate_total_directory_size(self):
        x = self.size()
        return f'{x // 1000} MB {x % 1000} KB'
