class StarshipRobotConstructor:
    def __init__(self, parts):
        self.parts = parts

    def find_assembly_order(self, target_component):
        components = []
        componentstates = {}
        for i in self.parts:
            componentstates[i] = 0
        x = self.order(target_component, components, componentstates)
        if x == -1:
            return []
        return components

    def order(self, component, components, componentstates):
        if componentstates[component] == 0:
            componentstates[component] = 1
            for i in self.parts[component]:
                x = self.order(i, components, componentstates)
                if x == -1:
                    return -1
            componentstates[component] = 2
            components.append(component)
        elif componentstates[component] == 1:
            return -1
